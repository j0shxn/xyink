+Offset = 90; % Degrees, 
+
+% The linear transformations are considered in a case where the X joint 
+% coincides with the X-Axis in the local coordinate frame and the Y joint
+% coincides with the Y-Axis similarly. Y joint is on top of the X joint
+% thus gets manipulated by it. Therefore for the East placement of the the
+% pedestal system an offset of 90 degrees must be added to the azimuth angle
+% furthermore the transformations are done in a frame where the Z-Axis points
+% UP thus being a NWU frame. So the negative of the azimuth angle is considered
+
+ModifiedAzimuth = mod(360 - (Azimuth + Offset), 360);
+SphericalP = deg2rad(ModifiedAzimuth);
+SphericalT = deg2rad(Elevation);
+losv = spherical2cartesian([SphericalP,SphericalT,1]);
+% Quadratic form to get the double roots of the X joint
+cotld = cos(ld)/sin(ld);
+nomp0 = -(losv(1)*cotld);
+nomp1 = sqrt( losv(1)^2 * cotld^2 - losv(2)^2 - losv(3)^2 );
+nom0 = nomp0 + nomp1;
+nom1 = nomp0 - nomp1;
+den = losv(2) - i * losv(3);
+
+% Normalize the X roots
+PSI0 = mod(real(-i*log(nom0/den)), 2*pi);
+PSI1 = mod(real(-i*log(nom1/den)), 2*pi);
+
+%fprintf("X roots are %d and %d\n", rad2deg(PSI0), rad2deg(PSI1))
+
+% Check which of the X roots are within mechanical boundaries of the system
+PSI0 = PSI0 - 2*pi*( PSI0 > pi );
+PSI1 = PSI1 - 2*pi*( PSI1 > pi );
+
+if PSI0 < pi/2 && PSI0 > -pi/2
+    PSI = PSI0;
+elseif PSI1 < pi/2 && PSI1 > -pi/2
+    PSI = PSI1;
+else
+    % The given azimuth and elevation angle are out of the workspace of the 
+    % pedestal. Give a warning but continue with taking the minimum (absolute)
+    % root.
+    fprintf("WARNING: Out of workspace at < %d , %d > \n",...
+        Azimuth_D, Elevation_D)
+    if abs(PSI0) < abs(PSI1)
+        PSI = PSI0;
+    elseif
+        PSI = PSI1;
+    end
 end
 
+% Rotation the X motor does to the tip point vector without Y rotation
+Rx = [ 1 0 0 ; 0 cos(PSI) -sin(PSI) ; 0 sin(PSI) cos(PSI)];
+Zhat = [0 ; 0 ; 1];
+Tipv = Rx * Zhat;
+
+% Original Y motor joint axis
+K0v = [ cos(ld) ; sin(ld) ; 0 ];
+
+% Rotated Y motor joint axis
+Kv = Rx * K0v;
+
+nTipLos = cross(Tipv, losv);
+TipLos = nTipLos / norm(nTipLos);
+unnormSign = dot(TipLos, Kv);
+
+% Warning, kind of funky
+if unnormSign < 0
+    phiSign = 1;
+elseif unnormSign > 0
+    phiSign = -1;
+else
+    phiSign = 0;
+end
+PHI = phiSign * acos( dot(Tipv, losv) );
+
+% Return the calculated XY angles
+X_Axis_d = rad2deg(PSI);
+Y_Axis_d = rad2deg(PHI);
+
 %% Limit the maximum velocity of X and Y Axis at 5 deg/s
